# ─────────────────────────────────────────────
# Trust-Flow Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Redis password (change before production!)
REDIS_PASSWORD=trustflow_redis_secret

# Prediction cache TTL in seconds (default 1 hour)
CACHE_TTL_SECONDS=3600

# Port the ML service is exposed on the host
ML_PORT=5000

# ML service URL used by Electron (leave as localhost for local Docker)
# Change to your server IP/domain when deploying remotely
ML_SERVICE_URL=http://localhost:5000
