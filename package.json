{
  "name": "trust-flow",
  "productName": "Trust-Flow",
  "version": "1.0.0",
  "description": "Zero-Trust AI-powered secure web browser with real-time phishing detection",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
